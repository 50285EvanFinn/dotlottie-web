{
  "name": "@lottiefiles/dotlottie-web",
  "version": "0.0.0",
  "description": "A JavaScript library for rendering Lottie and dotLottie animations in the browser.",
  "keywords": [
    "lottie",
    "dotlottie",
    "animation",
    "web",
    "canvas",
    "renderer"
  ],
  "homepage": "https://github.com/LottieFiles/dotlottie-web",
  "bugs": {
    "url": "https://github.com/LottieFiles/dotlottie-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LottieFiles/dotlottie-web.git"
  },
  "license": "MIT",
  "author": "LottieFiles",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "clean:all": "rimraf dist node_modules"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
